    {
      "name": "Projects - Create",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "var data = pm.response.json();",
              "if (data && data.id) {",
              "  pm.collectionVariables.set('projectId', String(data.id));",
              "}",
              "",
              "pm.test('projectId guardado en variable de coleccion', function () {",
              "  pm.expect(pm.collectionVariables.get('projectId')).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ],
